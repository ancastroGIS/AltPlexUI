# .env.example — copy to .env and fill in values
# ─────────────────────────────────────────────
# Never commit .env to git — it contains API keys.

# ── System ────────────────────────────────────────────────────
TZ=America/Los_Angeles
PUID=1000
PGID=1000

# ── Lumen ─────────────────────────────────────────────────────
LUMEN_PORT=7070
# Local address of your Plex server, reachable from inside Docker
PLEX_SERVER_URL=http://192.168.1.50:32400

# ── Arr API keys ──────────────────────────────────────────────
# Settings → General → API Key in each service's web UI.
# Lumen's nginx injects these server-side — users never see them.
RADARR_API_KEY=
SONARR_API_KEY=
LIDARR_API_KEY=
PROWLARR_API_KEY=

# ── Real-Debrid ────────────────────────────────────────────────
# Used by Lumen's nginx proxy (/api/rd/) and Zurg's config.
# Get it from: real-debrid.com → Account → API token
RD_API_KEY=

# ── Paths on the host ─────────────────────────────────────────
ARR_CONFIG=/opt/arrStack
MEDIA_BASE=/media/HDD_12tb
DOWNLOADS_PATH=/media/HDD_12tb/Downloads
MOVIES_PATH=/media/HDD_12tb/Movies
TV_PATH=/media/HDD_12tb/TV
MUSIC_PATH=/media/HDD_12tb/Music
WATCHLIST_PATH=/media/HDD_12tb/watchlistarr
SYMLINKS_PATH=/media/HDD_12tb/symLinks/watchlistarr/tv-sonarr

# ── Optional ──────────────────────────────────────────────────
FLARESOLVERR_LOG_LEVEL=info
